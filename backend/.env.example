# PostgreSQL Database Configuration
# Format: postgresql://username:password@host:port/database_name
# Change credentials to match your local PostgreSQL setup
DATABASE_URL=postgresql://postgres:XXXXX@localhost:5432/postgres

# JWT Authentication Config
JWT_SECRET=XXXXXXXXXXXX
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM Providers API Keys
# Add your active API keys here
GOOGLE_GEMINI_KEY="XXXXXXXXX"
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# AWS IAM Session Access Keys
AWS_ACCESS_KEY_ID=XXXXXXXX
AWS_SECRET_ACCESS_KEY=XXXXXXXX
AWS_DEFAULT_REGION=us-east-1